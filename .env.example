# Template only — no real secrets here. Copy to .env (gitignored) and fill it in.

# MongoDB Atlas connection string, or mongodb://localhost:27017 for a local server.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=Cluster0
MONGODB_DB=promptpilot
PORT=5000

# Free Groq API key: https://console.groq.com/keys
# Groq exposes an OpenAI-compatible API, so the official `openai` SDK is used as-is.
# Leave OPENAI_API_KEY empty to run in demo mode (canned responses from MongoDB).
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
